{
  "name": "emberflow-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev",
    "dev:api": "uv run --python 3.13 --with fastapi --with \"uvicorn[standard]\" --with-editable ../emberflow uvicorn api.index:app --reload --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^15.3.0",
    "papaparse": "^5.5.2",
    "plotly.js-dist-min": "^2.35.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/papaparse": "^5.3.15",
    "@types/plotly.js": "^2.35.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
